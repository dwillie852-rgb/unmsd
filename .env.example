# ─────────────────────────────────────────────────
# UNMSD Application — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# Server port (only used by legacy server.mjs, Next.js uses its own)
PORT=4173

# ── Admin credentials ──
# The admin username for duty officer dashboard login
ADMIN_USERNAME=admin

# The admin password (hashed with argon2id on first boot)
# CHANGE THIS before deploying to production!
ADMIN_PASSWORD=your-secure-password-here

# Display name for the admin user
ADMIN_NAME=Operations admin

# ── Email (optional) ──
# Resend API key for transactional email notifications
# Leave empty to disable email; application still works without it.
# RESEND_API_KEY=re_your_api_key_here

# ── Production ──
# Set by your hosting platform automatically, or set manually:
# NODE_ENV=production
